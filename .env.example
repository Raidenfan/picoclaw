# ── LLM Provider ──────────────────────────
# Uncomment and set the API key for your provider
# OPENROUTER_API_KEY=sk-or-v1-xxx
# ZHIPU_API_KEY=xxx
# ANTHROPIC_API_KEY=sk-ant-xxx
# OPENAI_API_KEY=sk-xxx
# GEMINI_API_KEY=xxx
# MODELSCOPE_API_KEY=xxx
# CLAUDE_CODE_OAUTH=xxx
# ── Chat Channel ──────────────────────────
# TELEGRAM_BOT_TOKEN=123456:ABC...
# DISCORD_BOT_TOKEN=xxx
# Feishu (飞书)
# PICOCLAW_CHANNELS_FEISHU_APP_ID=cli_xxx
# PICOCLAW_CHANNELS_FEISHU_APP_SECRET=xxx
# PICOCLAW_CHANNELS_FEISHU_RANDOM_REACTION_EMOJI=Typing,OneSecond
# Email channel
# PICOCLAW_CHANNELS_EMAIL_FROM=bot@example.com
# PICOCLAW_CHANNELS_EMAIL_SMTP_SERVER=smtp.example.com
# PICOCLAW_CHANNELS_EMAIL_SMTP_PORT=587
# PICOCLAW_CHANNELS_EMAIL_SMTP_USER=bot@example.com
# PICOCLAW_CHANNELS_EMAIL_SMTP_PASSWORD=xxx
# PICOCLAW_CHANNELS_EMAIL_SMTP_TLS=false
# PICOCLAW_CHANNELS_EMAIL_SMTP_STARTTLS=true
# PICOCLAW_CHANNELS_EMAIL_IMAP_SERVER=imap.example.com
# PICOCLAW_CHANNELS_EMAIL_IMAP_PORT=993
# PICOCLAW_CHANNELS_EMAIL_IMAP_USER=bot@example.com
# PICOCLAW_CHANNELS_EMAIL_IMAP_PASSWORD=xxx
# PICOCLAW_CHANNELS_EMAIL_IMAP_TLS=true
# PICOCLAW_CHANNELS_EMAIL_TLS=true  # legacy fallback for smtp/imap TLS if specific flags are unset
# PICOCLAW_CHANNELS_EMAIL_POLL_INTERVAL_SECS=30
# PICOCLAW_CHANNELS_EMAIL_WHITELIST_FILE=/etc/picoclaw/email-whitelist.txt
# PICOCLAW_CHANNELS_EMAIL_USAGE_FILE=/etc/picoclaw/email-usage.json
# PICOCLAW_CHANNELS_EMAIL_MAILBOX=INBOX
# PICOCLAW_CHANNELS_EMAIL_MAX_ATTACHMENT_SIZE_BYTES=10485760

# ── Web Search (optional) ────────────────
# BRAVE_SEARCH_API_KEY=BSA...

# ── Timezone ──────────────────────────────
TZ=Asia/Shanghai
